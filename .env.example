# WhiteRAG Environment Variables
# Copy this file to .env and fill in values as needed.

# HuggingFace token — suppresses rate limit warnings when downloading models
# Get yours at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# (Phase 5) OpenAI API key for answer generation
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
